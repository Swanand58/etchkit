{
  "name": "@etchkit/cli",
  "version": "0.0.2",
  "description": "CLI for etchkit — copy-paste UI components into your project",
  "main": "./dist/index.js",
  "bin": {
    "etchkit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "enquirer": "^2.4.1",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.29",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
